---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Therapist Database Access',
    body: 'Browse our verified database of Thai massage therapists ready to relocate. Every profile includes work history, skill ratings, photos, and video introductions — so you can evaluate candidates before reaching out.',
    img: '/images/Candidates-spolocna-Green-Lotus-1024x702.jpg',
    imgLeft: true,
    bullets: [
      'Hundreds of verified, work-ready profiles',
      'Video introductions and in-person skill evaluations',
      'Filter by age, experience, skills, and availability',
      'Database updated daily with new candidates',
    ],
    cta: { label: 'Browse Therapists', href: '/therapists' },
  },
  {
    title: 'Job Posting & Candidate Matching',
    body: 'Post your job requirements and let us do the headhunting. We match candidates to your specific criteria — location, skills, experience, salary range — and present you with a shortlist of pre-vetted therapists ready to accept your offer.',
    img: '/images/Sabaidee-therapists-1024x768.jpg',
    imgLeft: false,
    bullets: [
      'Post a job in under 5 minutes',
      'We shortlist candidates matching your exact criteria',
      'All candidates verified in our Bangkok office',
      'Maximum 6 business day turnaround from posting to placement',
    ],
    cta: { label: 'Post a Job', href: '/get-a-quote' },
  },
  {
    title: 'Visa, Documentation & Onboarding',
    body: 'International hiring means paperwork. We handle visa applications, work permits, contract preparation, and travel coordination — so your new therapist arrives ready to work from day one.',
    img: '/images/Main2.png',
    imgLeft: true,
    bullets: [
      'Visa and work permit processing',
      'Employment contract preparation',
      'Flight and travel coordination',
      'Pre-departure orientation for therapists',
    ],
    cta: { label: 'Get a Quote', href: '/get-a-quote' },
  },
  {
    title: 'Guarantees & Ongoing Support',
    body: 'Every placement is backed by our money-back guarantee. If a therapist doesn\'t meet expectations within the first month, we\'ll replace them or refund you — no questions asked. We stay involved after placement to ensure a smooth transition.',
    img: '/images/Main3.png',
    imgLeft: false,
    bullets: [
      '100% money-back guarantee within the first month',
      'Free replacement if therapist leaves early',
      'Ongoing support throughout the contract period',
      'Direct communication channel with placed therapists',
    ],
    cta: { label: 'Contact Us', href: '/contact' },
  },
];

const pricing = [
  { label: 'Single Placement', price: 'From $990', desc: 'One verified therapist, fully vetted and ready to relocate.', features: ['Full vetting & matching', 'Visa assistance', 'Money-back guarantee'] },
  { label: 'Team Hire (3+)', price: 'Custom Quote', desc: 'Hiring multiple therapists? Volume discounts and priority matching.', features: ['Dedicated account manager', 'Priority candidate access', 'Bulk visa processing'], highlight: true },
  { label: 'Ongoing Partnership', price: 'Contact Us', desc: 'For spas with regular staffing needs — preferred rates and first access to new candidates.', features: ['First access to new profiles', 'Preferred pricing', 'Quarterly staffing reviews'] },
];
---

<Layout
  title="Recruitment Services — Spa Company Bangkok"
  description="Thai therapist recruitment services: database access, candidate matching, visa processing, and placement guarantees for spas worldwide."
>

  <!-- Page Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">Recruitment Services</h1>
      <p class="text-white/85 text-lg">
        End-to-end Thai therapist recruitment — from sourcing and vetting to visa processing and placement. We handle everything so you can focus on running your spa.
      </p>
    </div>
  </section>

  <!-- Service Sections -->
  {services.map((s, i) => (
    <section class={`py-16 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class={`flex flex-col ${s.imgLeft ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-12`}>

          <div class="md:w-1/2">
            <img
              src={s.img}
              alt={s.title}
              class="rounded-2xl shadow-lg w-full object-cover max-h-80"
            />
          </div>

          <div class="md:w-1/2">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{s.title}</h2>
            <p class="text-gray-600 leading-relaxed mb-6">{s.body}</p>
            <ul class="space-y-2 mb-6">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-gray-600">{b}</span>
                </li>
              ))}
            </ul>
            <a href={s.cta.href}
              class="inline-block px-6 py-2.5 rounded-full bg-[#4a7c3f] text-white font-semibold text-sm hover:bg-[#2d5a27] transition-colors">
              {s.cta.label}
            </a>
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- How It Works (mini) -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-10">How Recruitment Works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-8">
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">1</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">Post a Job</h3>
          <p class="text-xs text-gray-500">Fill a quick form with your requirements and salary details.</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">2</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">We Match</h3>
          <p class="text-xs text-gray-500">Our team shortlists verified candidates that fit your criteria.</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">3</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">You Select</h3>
          <p class="text-xs text-gray-500">Review profiles, watch videos, and pick your preferred therapist.</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">4</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">We Deliver</h3>
          <p class="text-xs text-gray-500">We handle visa, travel, and onboarding. Your therapist arrives ready to work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-10">Pricing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {pricing.map((p) => (
          <div class={`rounded-2xl border-2 p-8 flex flex-col ${p.highlight ? 'border-[#4a7c3f] shadow-lg' : 'border-gray-200 bg-white'}`}>
            {p.highlight && (
              <div class="text-xs font-bold text-[#4a7c3f] uppercase tracking-widest mb-2">Most Popular</div>
            )}
            <h3 class="text-xl font-bold text-gray-900 mb-1">{p.label}</h3>
            <div class="text-2xl font-bold text-gray-900 mb-2">{p.price}</div>
            <p class="text-gray-500 text-sm mb-6">{p.desc}</p>
            <ul class="space-y-2 mb-8 flex-1">
              {p.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="w-4 h-4 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                    <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/get-a-quote"
              class={`block text-center py-3 rounded-full font-semibold transition-colors ${
                p.highlight
                  ? 'bg-[#4a7c3f] text-white hover:bg-[#2d5a27]'
                  : 'border-2 border-[#4a7c3f] text-[#4a7c3f] hover:bg-[#4a7c3f] hover:text-white'
              }`}>
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Hire?</h2>
      <p class="text-gray-400 mb-8">
        Post your job today and we'll have shortlisted candidates for you within days.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/get-a-quote"
          class="px-10 py-4 rounded-full bg-[#4a7c3f] text-white font-bold hover:bg-[#2d5a27] transition-colors"
        >
          Post a Job
        </a>
        <a
          href="/therapists"
          class="px-10 py-4 rounded-full border-2 border-white text-white font-bold hover:bg-white hover:text-gray-900 transition-colors"
        >
          Browse Therapists
        </a>
      </div>
    </div>
  </section>

</Layout>
