---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="หน้าแรก — Spa Company Bangkok"
  description="Spa Company Bangkok — พอร์ทัลจัดหานักบำบัดไทยที่ง่ายที่สุดในประเทศไทย"
>

  <!-- Hero -->
  <section
    class="relative min-h-[500px] flex items-center justify-center text-center bg-cover bg-center"
    style="background-image: url('/images/English-Banner-THerapist-.png');"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 px-4 max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        Spa Company Bangkok
      </h1>
      <p class="text-xl text-white/85 mb-2">
        พอร์ทัลจัดหานักบำบัดไทยที่ง่ายที่สุด
      </p>
      <p class="text-white/70 mb-8 text-lg">
        ค้นหานักบำบัดนวดไทยที่ผ่านการรับรองแล้ว พร้อมรับประกันผล
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://spa-company.com/login/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 rounded-full bg-[#a9cf54] text-white font-semibold hover:bg-[#588f27] transition-colors"
        >
          ลงทะเบียน / เข้าสู่ระบบ
        </a>
        <a
          href="/contact"
          class="px-8 py-3 rounded-full border-2 border-white text-white font-semibold hover:bg-white hover:text-gray-900 transition-colors"
        >
          ติดต่อเรา
        </a>
      </div>
    </div>
  </section>

  <!-- Why Spa Company (Thai) -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">ทำไมต้อง Spa Company?</h2>
      <p class="text-gray-600 mb-12 text-lg max-w-2xl mx-auto">
        เราช่วยให้สปาและโรงแรมทั่วโลกค้นหานักบำบัดไทยที่มีคุณภาพ ผ่านการตรวจสอบจากสำนักงานของเราในกรุงเทพฯ
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="p-6 bg-gray-50 rounded-2xl">
          <div class="text-4xl font-bold text-[#a9cf54] mb-2">500+</div>
          <div class="font-semibold text-gray-800 mb-1">นักบำบัดที่ผ่านการรับรอง</div>
          <p class="text-gray-500 text-sm">ฐานข้อมูลขนาดใหญ่ อัปเดตทุกวัน</p>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl">
          <div class="text-4xl font-bold text-[#a9cf54] mb-2">200+</div>
          <div class="font-semibold text-gray-800 mb-1">สปาที่ให้บริการ</div>
          <p class="text-gray-500 text-sm">ทั่วโลก ทั้งในยุโรปและเอเชีย</p>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl">
          <div class="text-4xl font-bold text-[#a9cf54] mb-2">24 ชม.</div>
          <div class="font-semibold text-gray-800 mb-1">การอนุมัติรวดเร็ว</div>
          <p class="text-gray-500 text-sm">ได้รับนักบำบัดภายใน 24 ชั่วโมงหลังอนุมัติ</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps (Thai) -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">ขั้นตอนการทำงาน</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
        {[
          { num: 1, label: 'เข้าสู่ระบบ', img: '/images/01-Log-In.png' },
          { num: 2, label: 'ลงประกาศงาน', img: '/images/02-Post-A-Job.png' },
          { num: 3, label: 'ชำระเงิน', img: '/images/03-Payment.png' },
          { num: 4, label: 'เลือกผู้สมัคร', img: '/images/04-Select-Candidates.png' },
          { num: 5, label: 'ตัดสินใจ', img: '/images/05-Decision-Time.png' },
          { num: 6, label: 'อนุมัติ', img: '/images/06-Approval.png' },
        ].map((s) => (
          <div class="flex flex-col items-center text-center">
            <div class="w-20 h-20 rounded-2xl bg-white border border-gray-100 flex items-center justify-center mb-3 shadow-sm">
              <img src={s.img} alt={s.label} class="w-14 h-14 object-contain" />
            </div>
            <div class="text-xs font-bold text-[#a9cf54] mb-1">{s.num}.</div>
            <div class="text-sm font-semibold text-gray-800">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#a9cf54] py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">อย่ารอช้า!</h2>
      <p class="text-white/85 mb-8 text-lg">
        ลงทะเบียนและเริ่มหางานในฝันของคุณได้แล้ววันนี้
      </p>
      <a
        href="https://spa-company.com/login/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-10 py-4 rounded-full bg-white text-[#588f27] font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        กดที่นี่เพื่อลงทะเบียน
      </a>
    </div>
  </section>

  <!-- Language switcher -->
  <div class="bg-gray-100 py-4 text-center">
    <p class="text-sm text-gray-500">
      View in English: <a href="/" class="text-[#a9cf54] hover:text-[#588f27] font-medium underline">Home</a>
    </p>
  </div>

</Layout>
