---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const team = [
  { role: lang === 'en' ? 'Recruitment Manager' : 'Manajer Rekrutmen' },
  { role: lang === 'en' ? 'Candidate Coordinator' : 'Koordinator Kandidat' },
  { role: lang === 'en' ? 'Document Specialist' : 'Spesialis Dokumen' },
];
---

<Layout
  title={lang === 'en' ? 'About Us — Spa Company Indonesia' : 'Tentang Kami — Spa Company Indonesia'}
  lang={lang}
>

  <!-- Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">{t(lang, 'about.hero.title')}</h1>
      <p class="text-white/85 text-lg">{t(lang, 'about.hero.subtitle')}</p>
    </div>
  </section>

  <!-- Permits & Registration -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">{t(lang, 'about.permits.title')}</h2>
      <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">{t(lang, 'about.permits.body')}</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Company Name -->
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">{lang === 'en' ? 'Company Name' : 'Nama Perusahaan'}</h3>
          </div>
          <p class="text-gray-600 text-sm">Spa Company Indonesia</p>
        </div>

        <!-- Office Address -->
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">{lang === 'en' ? 'Office Address' : 'Alamat Kantor'}</h3>
          </div>
          <p class="text-gray-500 text-sm italic">{lang === 'en' ? 'Coming soon' : 'Segera hadir'}</p>
        </div>

        <!-- Recruitment License -->
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">{lang === 'en' ? 'Recruitment License' : 'Lisensi Rekrutmen'}</h3>
          </div>
          <p class="text-gray-500 text-sm italic">{lang === 'en' ? 'In progress' : 'Dalam proses'}</p>
        </div>

        <!-- Contact -->
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#4a7c3f]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">{lang === 'en' ? 'Contact' : 'Kontak'}</h3>
          </div>
          <a href="https://wa.me/628211519986" target="_blank" rel="noopener noreferrer" class="text-[#4a7c3f] hover:text-[#2d5a27] text-sm font-medium transition-colors">
            +62 821 1519 986 (WhatsApp)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">{t(lang, 'about.team.title')}</h2>
      <p class="text-gray-600 text-center mb-10">{t(lang, 'about.team.body')}</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {team.map((member) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center">
            <div class="w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 mb-1">{member.role}</h3>
            <p class="text-gray-500 text-sm">{lang === 'en' ? 'Profile coming soon' : 'Profil segera hadir'}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-10">{t(lang, 'about.testimonials.title')}</h2>

      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <p class="text-gray-600 italic mb-3">
              {lang === 'en'
                ? '"The recruitment process was smooth and professional. Within weeks I had all my documents ready and was on a plane to start my new position. Highly recommended!"'
                : '"Proses rekrutmen berjalan lancar dan profesional. Dalam beberapa minggu semua dokumen saya siap dan saya sudah dalam perjalanan untuk memulai posisi baru. Sangat direkomendasikan!"'}
            </p>
            <div class="font-semibold text-gray-800 text-sm">{lang === 'en' ? 'Candidate Testimonial' : 'Testimoni Kandidat'}</div>
            <div class="text-gray-500 text-xs">{lang === 'en' ? 'Placed therapist, 2025' : 'Terapis ditempatkan, 2025'}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">
        {lang === 'en' ? 'Want to Work Overseas?' : 'Ingin Bekerja di Luar Negeri?'}
      </h2>
      <p class="text-white/85 mb-8 text-lg">
        {lang === 'en'
          ? 'Browse current job openings or send us your CV on WhatsApp.'
          : 'Lihat lowongan kerja saat ini atau kirim CV Anda via WhatsApp.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={localizedPath(lang, '/jobs')}
          class="px-10 py-4 rounded-full bg-white text-[#2d5a27] font-bold hover:bg-gray-100 transition-colors"
        >
          {t(lang, 'nav.jobs')}
        </a>
        <a
          href="https://wa.me/628211519986"
          target="_blank"
          rel="noopener noreferrer"
          class="px-10 py-4 rounded-full border-2 border-white text-white font-bold hover:bg-white hover:text-[#2d5a27] transition-colors"
        >
          {t(lang, 'contact.whatsapp')}
        </a>
      </div>
    </div>
  </section>

</Layout>
