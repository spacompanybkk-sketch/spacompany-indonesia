---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout
  title="Spa Company Indonesia — Lowongan Kerja Spa di Luar Negeri"
  description="Cari pekerjaan terapis spa di Eropa dan Timur Tengah. Proses cepat, aman, dan terpercaya. Gaji tinggi, akomodasi disediakan."
  lang={lang}
>

  <!-- Hero -->
  <section
    class="relative min-h-[560px] flex items-center justify-center text-center bg-cover bg-center"
    style="background-image: url('/images/id-hero.jpg');"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 px-4 max-w-3xl mx-auto">
      <img src="/images/spa-company-indonesia-logo-green.jpeg" alt="Spa Company Indonesia" class="h-24 mx-auto mb-6 rounded-lg" />
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        Kerja di Spa Luar Negeri?<br />Kami Bantu Anda!
      </h1>
      <p class="text-lg text-white/85 mb-8 max-w-xl mx-auto">
        Ratusan lowongan kerja terapis spa di Eropa dan Timur Tengah. Gaji tinggi, akomodasi disediakan, visa diurus. Daftar sekarang — gratis!
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={localizedPath(lang, '/jobs')}
          class="px-8 py-3 rounded-full bg-[#4a7c3f] text-white font-semibold hover:bg-[#2d5a27] transition-colors"
        >
          Lihat Lowongan Kerja
        </a>
        <a
          href="https://wa.me/628211519986?text=Halo%2C%20saya%20tertarik%20kerja%20di%20spa%20luar%20negeri"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 rounded-full border-2 border-white text-white font-semibold hover:bg-white hover:text-gray-900 transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hubungi via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-[#4a7c3f] text-white py-10">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-4xl font-bold mb-1">200+</div>
        <div class="text-white/80 font-medium">Lowongan Tersedia</div>
      </div>
      <div>
        <div class="text-4xl font-bold mb-1">15+</div>
        <div class="text-white/80 font-medium">Negara Tujuan</div>
      </div>
      <div>
        <div class="text-4xl font-bold mb-1">100%</div>
        <div class="text-white/80 font-medium">Gratis untuk Kandidat</div>
      </div>
    </div>
  </section>

  <!-- Feature 1: Banyak Lowongan -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-1/2">
          <img src="/images/id-jobs-abroad.jpg" alt="Lowongan Spa di Luar Negeri" class="rounded-2xl shadow-md w-full object-cover" />
        </div>
        <div class="md:w-1/2">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Ratusan Lowongan di Seluruh Dunia</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-6">
            Kami bekerja sama dengan ratusan spa dan hotel bintang lima di Eropa, Timur Tengah, dan Asia. Setiap minggu ada lowongan baru — mulai dari Slovakia, Jerman, Czech Republic, hingga Dubai dan Qatar.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Gaji €700 – €1.500 per bulan + komisi</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Akomodasi dan makan disediakan</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Tiket pesawat dan visa dibantu perusahaan</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature 2: Proses Cepat & Terpercaya -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row-reverse items-center gap-10">
        <div class="md:w-1/2">
          <img src="/images/id-trusted-agency.jpg" alt="Agen Rekrutmen Terpercaya" class="rounded-2xl shadow-md w-full object-cover" />
        </div>
        <div class="md:w-1/2">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Agen Rekrutmen Resmi & Terpercaya</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-6">
            Spa Company Indonesia adalah agen rekrutmen internasional berlisensi. Kami sudah membantu ratusan terapis Indonesia mendapatkan pekerjaan di luar negeri. Proses kami transparan, cepat, dan tanpa biaya untuk Anda.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Pendaftaran 100% gratis — tidak ada biaya tersembunyi</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Proses cepat — dari pendaftaran hingga keberangkatan dalam hitungan minggu</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span class="text-gray-600">Kami urus semua dokumen: visa, kontrak kerja, dan tiket pesawat</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature 3: Kisah Sukses -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-1/2">
          <img src="/images/id-success-story.jpg" alt="Kisah Sukses Terapis Indonesia" class="rounded-2xl shadow-md w-full object-cover" />
        </div>
        <div class="md:w-1/2">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Terapis Indonesia Sukses di Luar Negeri</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-6">
            Bergabunglah dengan ratusan terapis Indonesia yang sudah bekerja di spa-spa terbaik di Eropa. Mereka mendapatkan gaji yang baik, pengalaman internasional, dan kehidupan yang lebih baik untuk keluarga mereka.
          </p>
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
            <p class="text-gray-600 italic text-sm leading-relaxed">
              "Saya sangat bersyukur bisa bekerja di spa di Slovakia. Gajinya jauh lebih tinggi dan saya bisa mengirim uang untuk keluarga di Bali. Tim Spa Company sangat membantu dari awal sampai akhir."
            </p>
            <p class="text-gray-400 text-xs mt-2">— Terapis dari Bali, bekerja di Bratislava</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cara Mendaftar -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-3">Cara Mendaftar</h2>
      <p class="text-gray-500 mb-10">Proses mudah dan cepat — hanya 4 langkah!</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
        <div class="flex flex-col items-center text-center">
          <div class="w-14 h-14 rounded-full bg-[#4a7c3f] text-white text-xl font-bold flex items-center justify-center mb-3">1</div>
          <div class="text-sm font-semibold text-gray-800 mb-2">Kirim CV</div>
          <p class="text-xs text-gray-500 leading-relaxed">Upload CV atau hubungi kami via WhatsApp.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-14 h-14 rounded-full bg-[#4a7c3f] text-white text-xl font-bold flex items-center justify-center mb-3">2</div>
          <div class="text-sm font-semibold text-gray-800 mb-2">Wawancara</div>
          <p class="text-xs text-gray-500 leading-relaxed">Tim kami akan menghubungi untuk wawancara singkat.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-14 h-14 rounded-full bg-[#4a7c3f] text-white text-xl font-bold flex items-center justify-center mb-3">3</div>
          <div class="text-sm font-semibold text-gray-800 mb-2">Pilih Pekerjaan</div>
          <p class="text-xs text-gray-500 leading-relaxed">Kami carikan lowongan yang cocok untuk Anda.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-14 h-14 rounded-full bg-[#4a7c3f] text-white text-xl font-bold flex items-center justify-center mb-3">4</div>
          <div class="text-sm font-semibold text-gray-800 mb-2">Berangkat!</div>
          <p class="text-xs text-gray-500 leading-relaxed">Visa, tiket, dan kontrak diurus — Anda tinggal berangkat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CV Upload CTA -->
  <section
    class="relative py-16 bg-cover bg-center"
    style="background-image: url('/images/id-apply-now.jpg');"
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Siap Memulai Karir Internasional?</h2>
      <p class="text-white/85 mb-8 text-lg">
        Kirim CV Anda sekarang atau hubungi kami di WhatsApp. Pendaftaran gratis dan tanpa komitmen.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={localizedPath(lang, '/jobs')}
          class="px-8 py-3 rounded-full bg-[#4a7c3f] text-white font-semibold hover:bg-[#2d5a27] transition-colors"
        >
          Lihat Lowongan
        </a>
        <a
          href="https://wa.me/628211519986?text=Halo%2C%20saya%20ingin%20mendaftar%20kerja%20di%20spa%20luar%20negeri"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 rounded-full bg-[#25D366] text-white font-semibold hover:bg-[#1da851] transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Daftar via WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>
