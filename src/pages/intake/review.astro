---
import Layout from "../../layouts/Layout.astro";
import LoginGate from "../../components/LoginGate.astro";
---

<Layout title="Intake Review — Spa Company" description="Internal approval queue for candidate intake submissions">
  <LoginGate>
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Candidate Review Queue</h1>
        <p class="text-gray-500 mt-2">Approve or reject draft candidate submissions.</p>
      </div>

      <!-- Import from Notion button (approvers only) -->
      <div id="import-section" class="hidden mb-6 p-4 bg-blue-50 border border-blue-200 rounded-xl">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold text-blue-900">Import from Notion</p>
            <p class="text-xs text-blue-600">Import "Waiting Room" candidates from Notion as draft profiles.</p>
          </div>
          <button id="import-notion-btn"
            class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm py-2 px-4 rounded-lg transition-colors disabled:opacity-50">
            Import Waiting Room
          </button>
        </div>
        <p id="import-status" class="text-xs text-blue-700 mt-2 hidden"></p>
      </div>

      <!-- Migrate Therapists button (approvers only) -->
      <div id="migrate-section" class="hidden mb-6 p-4 bg-purple-50 border border-purple-200 rounded-xl">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold text-purple-900">Migrate Therapists</p>
            <p class="text-xs text-purple-600">One-time migration: copy old therapists into the unified candidates database.</p>
          </div>
          <button id="migrate-btn"
            class="bg-purple-600 hover:bg-purple-700 text-white font-semibold text-sm py-2 px-4 rounded-lg transition-colors disabled:opacity-50">
            Migrate Now
          </button>
        </div>
        <p id="migrate-status" class="text-xs text-purple-700 mt-2 hidden"></p>
      </div>

      <!-- Not-approver notice -->
      <div id="no-permission" class="hidden bg-yellow-50 border border-yellow-200 text-yellow-800 rounded-xl px-5 py-4 text-sm font-medium">
        You do not have permission to review candidates. Please contact an administrator.
      </div>

      <!-- Loading state -->
      <div id="review-loading" class="text-center py-16">
        <svg class="animate-spin w-8 h-8 text-[#4a7c3f] mx-auto mb-3" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <p class="text-gray-400 text-sm">Checking permissions…</p>
      </div>

      <!-- Empty state -->
      <div id="review-empty" class="hidden text-center py-16">
        <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <p class="text-gray-400 text-sm">No candidates pending review.</p>
      </div>

      <!-- Candidate cards -->
      <div id="review-list" class="hidden space-y-4"></div>

      <!-- Error -->
      <div id="review-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-4 text-sm"></div>
    </div>
  </LoginGate>
</Layout>

<script>
  import { collection, query, where, getDocs, doc, getDoc, updateDoc, serverTimestamp } from 'firebase/firestore';
  import { db, callFunction } from '../../lib/firebase.js';

  const loadingEl = document.getElementById('review-loading')!;
  const emptyEl = document.getElementById('review-empty')!;
  const listEl = document.getElementById('review-list')!;
  const noPermEl = document.getElementById('no-permission')!;
  const errorEl = document.getElementById('review-error')!;

  function showError(msg: string) {
    loadingEl.classList.add('hidden');
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  async function initReview(email: string) {
    try {
      // Check if user is an approver
      const approverDoc = await getDoc(doc(db, 'config', 'approvers'));
      if (!approverDoc.exists()) {
        loadingEl.classList.add('hidden');
        noPermEl.classList.remove('hidden');
        return;
      }

      const approvers: string[] = approverDoc.data()?.approverEmails || approverDoc.data()?.emails || [];
      if (!approvers.includes(email)) {
        loadingEl.classList.add('hidden');
        noPermEl.classList.remove('hidden');
        return;
      }

      // Show import from Notion button for approvers
      const importSection = document.getElementById('import-section')!;
      const importBtn = document.getElementById('import-notion-btn') as HTMLButtonElement;
      const importStatus = document.getElementById('import-status')!;
      importSection.classList.remove('hidden');

      importBtn.addEventListener('click', async () => {
        importBtn.disabled = true;
        importBtn.textContent = 'Importing…';
        importStatus.classList.remove('hidden');
        importStatus.textContent = 'Querying Notion for Waiting Room candidates…';

        try {
          const result = await callFunction('importFromNotion', { callerEmail: email }) as { data: { imported: number; skipped: number; errors: any[] } };
          const { imported, skipped, errors } = result.data;
          importStatus.textContent = `Done: ${imported} imported, ${skipped} skipped${errors.length > 0 ? `, ${errors.length} errors` : ''}. Refresh to see new drafts.`;
          importBtn.textContent = 'Import Complete';
        } catch (err) {
          importStatus.textContent = `Import failed: ${(err as Error).message}`;
          importBtn.disabled = false;
          importBtn.textContent = 'Retry Import';
        }
      });

      // Migrate therapists button
      const migrateSection = document.getElementById('migrate-section')!;
      const migrateBtn = document.getElementById('migrate-btn') as HTMLButtonElement;
      const migrateStatus = document.getElementById('migrate-status')!;
      migrateSection.classList.remove('hidden');

      migrateBtn.addEventListener('click', async () => {
        migrateBtn.disabled = true;
        migrateBtn.textContent = 'Migrating…';
        migrateStatus.classList.remove('hidden');
        migrateStatus.textContent = 'Copying therapists to candidates database…';

        try {
          const result = await callFunction('migrateTherapists', { callerEmail: email }) as { data: { migrated: number; skipped: number; errors: any[] } };
          const { migrated, skipped, errors } = result.data;
          migrateStatus.textContent = `Done: ${migrated} migrated, ${skipped} skipped${errors.length > 0 ? `, ${errors.length} errors` : ''}. Refresh to see them.`;
          migrateBtn.textContent = 'Migration Complete';
        } catch (err) {
          migrateStatus.textContent = `Migration failed: ${(err as Error).message}`;
          migrateBtn.disabled = false;
          migrateBtn.textContent = 'Retry Migration';
        }
      });

      // Load draft candidates
      const q = query(collection(db, 'candidates'), where('status', '==', 'draft'));
      const snap = await getDocs(q);
      loadingEl.classList.add('hidden');

      if (snap.empty) {
        emptyEl.classList.remove('hidden');
        return;
      }

      listEl.classList.remove('hidden');

      snap.forEach(docSnap => {
        const data = docSnap.data();
        const card = buildCard(docSnap.id, data);
        listEl.appendChild(card);
      });

    } catch (err) {
      showError(`Failed to load review queue: ${(err as Error).message}`);
    }
  }

  function buildCard(candidateId: string, data: Record<string, unknown>): HTMLElement {
    const card = document.createElement('div');
    card.id = `card-${candidateId}`;
    card.className = 'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 transition-opacity duration-500';

    const name = (data.fullName as string) || '(No name)';
    const position = (data.jobPosition as string) || '—';
    const nationality = (data.nationality as string) || '—';
    const submitter = (data.recruiterEmail as string) || '—';
    const notionUrl = (data.notionCandidateUrl as string) || '';
    const dateApplied = (data.dateApplied as string) || '';

    card.innerHTML = `
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-base font-semibold text-gray-900">${escapeHtml(name)}</h3>
          <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
            <span><strong class="text-gray-700">Position:</strong> ${escapeHtml(position)}</span>
            <span><strong class="text-gray-700">Nationality:</strong> ${escapeHtml(nationality)}</span>
            <span><strong class="text-gray-700">Submitted by:</strong> ${escapeHtml(submitter)}</span>
            ${dateApplied ? `<span><strong class="text-gray-700">Applied:</strong> ${escapeHtml(dateApplied)}</span>` : ''}
          </div>
          ${notionUrl ? `
            <a href="${escapeHtml(notionUrl)}" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs text-[#2d5a27] hover:underline mt-2">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              View in Notion
            </a>
          ` : ''}
        </div>
        <div class="flex gap-3 shrink-0">
          <button
            class="approve-btn px-4 py-2 bg-[#4a7c3f] text-white text-sm font-semibold rounded-lg hover:bg-[#2d5a27] transition-colors disabled:opacity-50"
            data-id="${candidateId}"
          >
            Approve
          </button>
          <button
            class="reject-btn px-4 py-2 bg-red-500 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition-colors disabled:opacity-50"
            data-id="${candidateId}"
          >
            Reject
          </button>
        </div>
      </div>
      <div class="action-result mt-3 text-sm font-medium hidden"></div>
    `;

    card.querySelector('.approve-btn')?.addEventListener('click', () => handleAction(candidateId, 'approved', card));
    card.querySelector('.reject-btn')?.addEventListener('click', () => handleAction(candidateId, 'rejected', card));

    return card;
  }

  async function handleAction(candidateId: string, action: 'approved' | 'rejected', card: HTMLElement) {
    const approveBtns = card.querySelectorAll<HTMLButtonElement>('button');
    approveBtns.forEach(b => { b.disabled = true; });

    try {
      await updateDoc(doc(db, 'candidates', candidateId), {
        status: action,
        reviewedAt: serverTimestamp(),
      });

      const resultEl = card.querySelector('.action-result')!;
      resultEl.textContent = action === 'approved' ? 'Approved.' : 'Rejected.';
      resultEl.className = `action-result mt-3 text-sm font-medium ${action === 'approved' ? 'text-green-700' : 'text-red-600'}`;
      resultEl.classList.remove('hidden');

      // Fade out card after a delay
      setTimeout(() => {
        card.style.opacity = '0';
        setTimeout(() => {
          card.remove();
          // Check if list is now empty
          if (listEl.children.length === 0) {
            listEl.classList.add('hidden');
            emptyEl.classList.remove('hidden');
          }
        }, 500);
      }, 1500);

    } catch (err) {
      const resultEl = card.querySelector('.action-result')!;
      resultEl.textContent = `Error: ${(err as Error).message}`;
      resultEl.className = 'action-result mt-3 text-sm font-medium text-red-600';
      resultEl.classList.remove('hidden');
      approveBtns.forEach(b => { b.disabled = false; });
    }
  }

  function escapeHtml(str: unknown): string {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  // Wait for authentication before loading
  document.addEventListener('intake-authenticated', (e: Event) => {
    const evt = e as CustomEvent<{ email: string }>;
    initReview(evt.detail.email);
  });

  // Fallback: if LoginGate already authenticated before this script loaded,
  // the event was missed. Check window flag and call initReview directly.
  if (window.__intakeUserEmail) {
    initReview(window.__intakeUserEmail);
  }
</script>
