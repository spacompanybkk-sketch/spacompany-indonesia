---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: 'Large Database of Thai Therapists',
    body: 'Every time you visit our site there is an online database of Thai therapists ready to go overseas. The database is updated daily so your time is never wasted.',
    img: '/images/Main1-1.png',
    imgLeft: true,
    subs: [
      { title: 'SHEER NUMBERS', img: '/images/sub1-1.png', body: 'Hundreds of verified therapists to search from, all confirmed in our office.' },
      { title: 'UPDATES', img: '/images/sub1-2.png', body: 'Our database is regularly updated with real and verified people.' },
      { title: 'GREAT PROFILES', img: '/images/sub1-3.png', body: 'Profiles include work experience, short videos and therapist evaluations.' },
    ],
  },
  {
    title: 'Find Your Personnel Quickly',
    body: 'Get a therapist within 24 hours of approving a job offer. Lower the time spent on ineffective HR tasks and focus on your core business. We guarantee a maximum 6 business day turnaround.',
    img: '/images/Main2.png',
    imgLeft: false,
    subs: [
      { title: 'QUICK APPROVAL', img: '/images/sub2-1.png', body: 'After you shortlist candidates, we approve therapists for the job as quickly as possible, explaining all work conditions and visa processes.' },
      { title: 'SAVE TIME', img: '/images/sub2-2.png', body: 'Automated processes save your time. Constantly updated profiles with real job-seekers.' },
      { title: 'MONEY BACK', img: '/images/sub2-3.png', body: 'Refund 100% if you are unhappy with the selected candidate within the first month. No questions asked.' },
    ],
  },
  {
    title: 'Guarantees for Peace of Mind',
    body: 'International recruiting is complicated. We offer a wide range of guarantees to secure your peace of mind — from multi-step verifications and control mechanisms to a money-back guarantee.',
    img: '/images/Main3.png',
    imgLeft: true,
    subs: [
      { title: 'VERIFIED', img: '/images/sub3-1.png', body: 'Hundreds of verified therapists to choose from. What you see is what you get.' },
      { title: 'LIVE CHAT', img: '/images/sub3-2.png', body: 'Chat online with approved therapists to discuss work details directly.' },
      { title: 'GUARANTEE', img: '/images/sub3-3.png', body: 'Money-back guarantee — refund 100% if unhappy within the first month. Some conditions apply.' },
    ],
  },
];

const steps = [
  { num: 1, label: 'Post a Job', img: '/images/02-Post-A-Job.png', body: 'Fill a quick form with your spa details and job requirements. Takes under 5 minutes — we verify everything on our side.' },
  { num: 2, label: 'Payment & Verification', img: '/images/03-Payment.png', body: 'Pay via PayPal or bank transfer. After payment your job goes live and is viewed by hundreds of therapists.' },
  { num: 3, label: 'Browse Candidates', img: '/images/04-Select-Candidates.png', body: 'Search our online database, watch therapist videos, read evaluations, and shortlist your favourites.' },
  { num: 4, label: 'Select & Approve', img: '/images/06-Approval.png', body: 'Make your final selection. We handle documentation, visa support, and ensure a smooth onboarding process.' },
];
---

<Layout
  title="Spa Company Bangkok — Thailand's Easiest Therapist Recruiting Portal"
  description="Find verified Thai massage therapists for your spa. Large database, 24-hour approval, and a money-back guarantee."
>

  <!-- Hero -->
  <section
    class="relative min-h-[560px] flex items-center justify-center text-center bg-cover bg-center"
    style="background-image: url('/images/spa-massage-hero.jpg');"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 px-4 max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        Thailand's Easiest<br />Therapist Recruiting Portal
      </h1>
      <p class="text-lg text-white/85 mb-8 max-w-xl mx-auto">
        Looking for Thai massage therapists to join your team? You're in the right place. Great profiles, updated daily.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/therapists"
          class="px-8 py-3 rounded-full bg-[#a9cf54] text-white font-semibold hover:bg-[#588f27] transition-colors"
        >
          Search Therapists
        </a>
        <a
          href="/get-a-quote"
          class="px-8 py-3 rounded-full border-2 border-white text-white font-semibold hover:bg-white hover:text-gray-900 transition-colors"
        >
          Post a Job
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-[#a9cf54] text-white py-10">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-4xl font-bold mb-1">500+</div>
        <div class="text-white/80 font-medium">Verified Therapists</div>
      </div>
      <div>
        <div class="text-4xl font-bold mb-1">200+</div>
        <div class="text-white/80 font-medium">Spas Served</div>
      </div>
      <div>
        <div class="text-4xl font-bold mb-1">24 hr</div>
        <div class="text-white/80 font-medium">Approval Turnaround</div>
      </div>
    </div>
  </section>

  <!-- Features -->
  {features.map((f, fi) => (
    <section class={`py-16 ${fi % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Main Feature Row -->
        <div class={`flex flex-col ${f.imgLeft ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-10 mb-12`}>
          <div class="md:w-1/2">
            <img src={f.img} alt={f.title} class="rounded-2xl shadow-md w-full object-cover" />
          </div>
          <div class="md:w-1/2">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{f.title}</h2>
            <p class="text-gray-600 leading-relaxed text-lg">{f.body}</p>
          </div>
        </div>

        <!-- Sub-features -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {f.subs.map((s) => (
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center">
              <img src={s.img} alt={s.title} class="w-24 h-24 object-cover mx-auto mb-4 rounded-xl" />
              <h3 class="font-semibold text-gray-800 mb-2 text-sm tracking-wide uppercase">{s.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>
  ))}

  <!-- Book CTA Banner -->
  <section class="bg-gray-900 py-14">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">How to Run a Spa</h2>
      <p class="text-gray-300 mb-6 text-lg">
        Get the management book for all Spa &amp; Wellness operators. A decade of experience and trends in one place — verified tips to increase profit, customer retention, and operational effectiveness.
      </p>
      <a
        href="/book"
        class="inline-block px-8 py-3 rounded-full bg-[#a9cf54] text-white font-semibold hover:bg-[#588f27] transition-colors"
      >
        Learn More
      </a>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">How It Works</h2>
        <p class="text-gray-500">Please pay close attention to the following steps.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
        {steps.map((s) => (
          <div class="flex flex-col items-center text-center group">
            <div class="w-20 h-20 rounded-2xl bg-gray-50 border border-gray-100 flex items-center justify-center mb-3 group-hover:border-[#a9cf54] transition-colors">
              <img src={s.img} alt={s.label} class="w-14 h-14 object-contain" />
            </div>
            <div class="text-xs font-bold text-[#a9cf54] mb-1">{s.num}.</div>
            <div class="text-sm font-semibold text-gray-800 mb-2">{s.label}</div>
            <p class="text-xs text-gray-500 leading-relaxed hidden lg:block">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-[#a9cf54] py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Find Your Next Therapist?</h2>
      <p class="text-white/85 mb-8 text-lg">
        Get started today and connect with hundreds of verified Thai massage therapists.
      </p>
      <a
        href="/contact"
        class="inline-block px-10 py-4 rounded-full bg-white text-[#588f27] font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        Get a Quote
      </a>
    </div>
  </section>

</Layout>
