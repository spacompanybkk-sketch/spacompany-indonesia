---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout
  title={lang === 'en' ? 'Job Board — Spa Company Indonesia' : 'Lowongan Kerja — Spa Company Indonesia'}
  lang={lang}
>

  <!-- Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">{t(lang, 'jobs.hero.title')}</h1>
      <p class="text-white/85 text-lg">{t(lang, 'jobs.hero.subtitle')}</p>
    </div>
  </section>

  <!-- Search + Upload -->
  <section class="bg-white border-b border-gray-200 py-6">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex flex-col sm:flex-row gap-4 items-center">
        <div class="flex-1 w-full">
          <input
            type="text"
            id="job-search"
            placeholder={t(lang, 'jobs.search')}
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm"
          />
        </div>
        <div>
          <label class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#4a7c3f] text-white font-semibold text-sm hover:bg-[#2d5a27] transition-colors cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            {t(lang, 'jobs.uploadCv')}
            <input type="file" id="cv-upload" accept=".pdf,.doc,.docx" class="hidden" />
          </label>
        </div>
      </div>
      <div id="cv-status" class="hidden mt-3 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-2"></div>
    </div>
  </section>

  <!-- Job Listings -->
  <section class="py-12 bg-gray-50 min-h-[400px]">
    <div class="max-w-5xl mx-auto px-4">

      <!-- Loading -->
      <div id="jobs-loading" class="flex flex-col items-center justify-center py-16">
        <div class="w-10 h-10 border-4 border-gray-200 border-t-[#4a7c3f] rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500 text-sm">{lang === 'en' ? 'Loading jobs...' : 'Memuat lowongan...'}</p>
      </div>

      <!-- Empty state -->
      <div id="jobs-empty" class="hidden text-center py-16">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500">{t(lang, 'jobs.noJobs')}</p>
      </div>

      <!-- Job cards container -->
      <div id="jobs-container" class="hidden space-y-4"></div>

    </div>
  </section>

  <!-- WhatsApp CTA -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">
        {lang === 'en' ? "Don't see the right job?" : 'Tidak menemukan lowongan yang tepat?'}
      </h2>
      <p class="text-white/85 mb-8 text-lg">
        {lang === 'en'
          ? 'Send us your CV on WhatsApp and we will match you with upcoming opportunities.'
          : 'Kirim CV Anda via WhatsApp dan kami akan mencocokkan Anda dengan peluang yang akan datang.'}
      </p>
      <a
        href="https://wa.me/628211519986"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-4 rounded-full bg-white text-[#2d5a27] font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {t(lang, 'contact.whatsapp')}
      </a>
    </div>
  </section>

</Layout>

<script>
  import { callFunction, storage } from '../../lib/firebase.js';
  import { ref, uploadBytes } from 'firebase/storage';

  interface Job {
    id: string;
    title?: string;
    location?: string;
    industry?: string;
    salary?: string;
    description?: string;
  }

  let allJobs: Job[] = [];

  // Load jobs
  async function loadJobs() {
    const loadingEl = document.getElementById('jobs-loading')!;
    const emptyEl = document.getElementById('jobs-empty')!;
    const containerEl = document.getElementById('jobs-container')!;

    try {
      const result = await callFunction('fetchJobs', {});
      allJobs = (result.data as any)?.jobs || [];

      loadingEl.classList.add('hidden');

      if (allJobs.length === 0) {
        emptyEl.classList.remove('hidden');
      } else {
        containerEl.classList.remove('hidden');
        renderJobs(allJobs);
      }
    } catch (err) {
      loadingEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
    }
  }

  function renderJobs(jobs: Job[]) {
    const container = document.getElementById('jobs-container')!;
    container.innerHTML = '';

    jobs.forEach((job) => {
      const card = document.createElement('div');
      card.className = 'bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow';
      card.innerHTML = `
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="flex-1">
            <h3 class="text-lg font-bold text-gray-900 mb-1">${job.title || 'Untitled Position'}</h3>
            <div class="flex flex-wrap gap-3 text-sm text-gray-500 mb-3">
              ${job.location ? `<span class="flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>${job.location}</span>` : ''}
              ${job.industry ? `<span class="flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>${job.industry}</span>` : ''}
              ${job.salary ? `<span class="flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>${job.salary}</span>` : ''}
            </div>
            ${job.description ? `<p class="text-gray-600 text-sm leading-relaxed">${job.description}</p>` : ''}
          </div>
          <a
            href="https://wa.me/628211519986?text=${encodeURIComponent('Hi, I am interested in the position: ' + (job.title || 'Job'))}"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[#25D366] text-white font-semibold text-sm hover:bg-[#1da851] transition-colors shrink-0"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Apply via WhatsApp
          </a>
        </div>
      `;
      container.appendChild(card);
    });
  }

  // Search filter
  document.getElementById('job-search')?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    if (!query) {
      renderJobs(allJobs);
      return;
    }
    const filtered = allJobs.filter((j) =>
      (j.title || '').toLowerCase().includes(query) ||
      (j.location || '').toLowerCase().includes(query) ||
      (j.industry || '').toLowerCase().includes(query) ||
      (j.description || '').toLowerCase().includes(query)
    );
    renderJobs(filtered);
  });

  // CV Upload
  document.getElementById('cv-upload')?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    const statusEl = document.getElementById('cv-status')!;
    statusEl.textContent = 'Uploading...';
    statusEl.classList.remove('hidden');
    statusEl.className = 'mt-3 text-sm text-blue-700 bg-blue-50 border border-blue-200 rounded-lg px-4 py-2';

    try {
      const storageRef = ref(storage, `cvs/${Date.now()}-${file.name}`);
      await uploadBytes(storageRef, file);
      statusEl.textContent = 'CV uploaded successfully!';
      statusEl.className = 'mt-3 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-2';
    } catch (err) {
      statusEl.textContent = `Upload failed: ${(err as Error).message}`;
      statusEl.className = 'mt-3 text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-4 py-2';
    }
  });

  // Init
  loadJobs();
</script>
