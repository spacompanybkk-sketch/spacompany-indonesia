---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const services = [
  {
    titleKey: 'service.headhunting.title' as const,
    bodyKey: 'service.headhunting.body' as const,
    img: '/images/service-candidates-group.jpg',
    imgLeft: true,
    bullets: lang === 'en'
      ? [
          'Targeted candidate search based on your exact requirements',
          'Access to hundreds of verified therapists across Indonesia',
          'Skill-based matching: massage type, experience, language',
          'Shortlists delivered within days of posting',
        ]
      : [
          'Pencarian kandidat berdasarkan kebutuhan spesifik Anda',
          'Akses ke ratusan terapis terverifikasi di seluruh Indonesia',
          'Pencocokan berbasis keterampilan: jenis pijat, pengalaman, bahasa',
          'Daftar pendek dikirim dalam hitungan hari',
        ],
    cta: { labelKey: 'common.getStarted' as const, href: '/get-a-quote' },
  },
  {
    titleKey: 'service.screening.title' as const,
    bodyKey: 'service.screening.body' as const,
    img: '/images/service-screening.jpg',
    imgLeft: false,
    bullets: lang === 'en'
      ? [
          'In-person identity and qualification verification',
          'Hands-on skill evaluation at our Indonesia office',
          'Work history and reference checks',
          'Video introductions and profile documentation',
        ]
      : [
          'Verifikasi identitas dan kualifikasi secara langsung',
          'Evaluasi keterampilan langsung di kantor Indonesia kami',
          'Pemeriksaan riwayat kerja dan referensi',
          'Video perkenalan dan dokumentasi profil',
        ],
    cta: { labelKey: 'common.learnMore' as const, href: '/contact' },
  },
  {
    titleKey: 'service.documents.title' as const,
    bodyKey: 'service.documents.body' as const,
    img: '/images/Main2.png',
    imgLeft: true,
    bullets: lang === 'en'
      ? [
          'Visa and work permit applications',
          'Employment contract preparation',
          'Government compliance and legal documentation',
          'Pre-departure orientation for candidates',
        ]
      : [
          'Aplikasi visa dan izin kerja',
          'Persiapan kontrak kerja',
          'Kepatuhan pemerintah dan dokumentasi hukum',
          'Orientasi pra-keberangkatan untuk kandidat',
        ],
    cta: { labelKey: 'quote.hero.title' as const, href: '/get-a-quote' },
  },
  {
    titleKey: 'service.flight.title' as const,
    bodyKey: 'service.flight.body' as const,
    img: '/images/Main3.png',
    imgLeft: false,
    bullets: lang === 'en'
      ? [
          'Flight booking and itinerary coordination',
          'Departure orientation and briefing',
          'Arrival coordination with your spa',
          'Emergency travel support',
        ]
      : [
          'Pemesanan penerbangan dan koordinasi jadwal',
          'Orientasi dan briefing keberangkatan',
          'Koordinasi kedatangan dengan spa Anda',
          'Dukungan perjalanan darurat',
        ],
    cta: { labelKey: 'common.contactUs' as const, href: '/contact' },
  },
  {
    titleKey: 'service.aftercare.title' as const,
    bodyKey: 'service.aftercare.body' as const,
    img: '/images/service-candidates-group.jpg',
    imgLeft: true,
    bullets: lang === 'en'
      ? [
          'Performance check-ins during the first 3 months',
          'Contract renewal coordination',
          'Replacement guarantee if placement does not work out',
          'Therapist welfare monitoring and support',
        ]
      : [
          'Pemeriksaan kinerja selama 3 bulan pertama',
          'Koordinasi perpanjangan kontrak',
          'Jaminan penggantian jika penempatan tidak berhasil',
          'Pemantauan dan dukungan kesejahteraan terapis',
        ],
    cta: { labelKey: 'common.contactUs' as const, href: '/contact' },
  },
];
---

<Layout
  title={lang === 'en' ? 'Our Services — Spa Company Indonesia' : 'Layanan Kami — Spa Company Indonesia'}
  lang={lang}
>

  <!-- Page Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">{t(lang, 'service.hero.title')}</h1>
      <p class="text-white/85 text-lg">
        {t(lang, 'service.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- Service Sections -->
  {services.map((s, i) => (
    <section class={`py-16 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class={`flex flex-col ${s.imgLeft ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-12`}>

          <div class="md:w-1/2">
            <img
              src={s.img}
              alt={t(lang, s.titleKey)}
              class="rounded-2xl shadow-lg w-full object-cover max-h-80"
            />
          </div>

          <div class="md:w-1/2">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{t(lang, s.titleKey)}</h2>
            <p class="text-gray-600 leading-relaxed mb-6">{t(lang, s.bodyKey)}</p>
            <ul class="space-y-2 mb-6">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 w-5 h-5 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-gray-600">{b}</span>
                </li>
              ))}
            </ul>
            <a href={localizedPath(lang, s.cta.href)}
              class="inline-block px-6 py-2.5 rounded-full bg-[#4a7c3f] text-white font-semibold text-sm hover:bg-[#2d5a27] transition-colors">
              {t(lang, s.cta.labelKey)}
            </a>
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- How It Works (mini) -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-10">{lang === 'en' ? 'How Recruitment Works' : 'Cara Kerja Rekrutmen'}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-8">
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">1</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">{t(lang, 'home.step1.label')}</h3>
          <p class="text-xs text-gray-500">{lang === 'en' ? 'Fill a quick form with your requirements and salary details.' : 'Isi formulir singkat dengan persyaratan dan detail gaji Anda.'}</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">2</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">{lang === 'en' ? 'We Match' : 'Kami Mencocokkan'}</h3>
          <p class="text-xs text-gray-500">{lang === 'en' ? 'Our team shortlists verified candidates that fit your criteria.' : 'Tim kami memilih kandidat terverifikasi yang sesuai kriteria Anda.'}</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">3</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">{lang === 'en' ? 'You Select' : 'Anda Memilih'}</h3>
          <p class="text-xs text-gray-500">{lang === 'en' ? 'Review profiles, watch videos, and pick your preferred therapist.' : 'Tinjau profil, tonton video, dan pilih terapis pilihan Anda.'}</p>
        </div>
        <div>
          <div class="w-12 h-12 rounded-full bg-[#4a7c3f] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3">4</div>
          <h3 class="font-semibold text-gray-900 mb-1 text-sm">{lang === 'en' ? 'We Deliver' : 'Kami Mengirim'}</h3>
          <p class="text-xs text-gray-500">{lang === 'en' ? 'We handle visa, travel, and onboarding. Your therapist arrives ready to work.' : 'Kami mengurus visa, perjalanan, dan onboarding. Terapis Anda tiba siap bekerja.'}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-900 py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">{lang === 'en' ? 'Ready to Hire?' : 'Siap Merekrut?'}</h2>
      <p class="text-gray-400 mb-8">
        {lang === 'en'
          ? "Post your job today and we'll have shortlisted candidates for you within days."
          : 'Pasang lowongan hari ini dan kami akan menyiapkan kandidat terpilih dalam hitungan hari.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={localizedPath(lang, '/get-a-quote')}
          class="px-10 py-4 rounded-full bg-[#4a7c3f] text-white font-bold hover:bg-[#2d5a27] transition-colors"
        >
          {t(lang, 'home.hero.ctaEmployer')}
        </a>
        <a
          href="https://wa.me/628211519986"
          target="_blank"
          rel="noopener noreferrer"
          class="px-10 py-4 rounded-full border-2 border-white text-white font-bold hover:bg-white hover:text-gray-900 transition-colors"
        >
          {t(lang, 'contact.whatsapp')}
        </a>
      </div>
    </div>
  </section>

</Layout>
