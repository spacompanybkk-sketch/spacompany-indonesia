---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout
  title={lang === 'en' ? 'Contact Us — Spa Company Indonesia' : 'Hubungi Kami — Spa Company Indonesia'}
  lang={lang}
>

  <!-- Page Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">{t(lang, 'contact.hero.title')}</h1>
      <p class="text-white/85 text-lg">
        {t(lang, 'contact.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12">

        <!-- Contact Info -->
        <div class="lg:w-2/5">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{t(lang, 'footer.getInTouch')}</h2>

          <div class="space-y-5 mb-8">
            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">{lang === 'en' ? 'Location' : 'Lokasi'}</div>
                <div class="text-gray-600 text-sm">{t(lang, 'footer.location')}</div>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">Email</div>
                <a href="mailto:info@spacompany-indonesia.com" class="text-[#4a7c3f] hover:text-[#2d5a27] text-sm transition-colors">
                  info@spacompany-indonesia.com
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">WhatsApp</div>
                <a
                  href="https://wa.me/628211519986"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#4a7c3f] hover:text-[#2d5a27] text-sm transition-colors"
                >
                  +62 821 1519 986
                </a>
              </div>
            </div>

            <!-- Response time -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">{lang === 'en' ? 'Response Time' : 'Waktu Respons'}</div>
                <div class="text-gray-600 text-sm">{lang === 'en' ? 'We reply within 1 business day' : 'Kami merespons dalam 1 hari kerja'}</div>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/628211519986"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full py-4 rounded-xl bg-[#25D366] text-white font-semibold hover:bg-[#1da851] transition-colors"
          >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {t(lang, 'contact.whatsapp')}
          </a>
        </div>

        <!-- Contact Form -->
        <div class="lg:w-3/5">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{lang === 'en' ? 'Send Us a Message' : 'Kirim Pesan'}</h2>

          <div id="contact-success" class="hidden bg-green-50 border-2 border-green-200 rounded-2xl p-8 text-center">
            <div class="text-3xl mb-2">&#10003;</div>
            <h3 class="text-xl font-bold text-green-800 mb-2">{t(lang, 'contact.form.success')}</h3>
            <p class="text-green-700">{t(lang, 'contact.form.successBody')}</p>
          </div>

          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'contact.form.name')} <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder={lang === 'en' ? 'Your name' : 'Nama Anda'}
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'contact.form.phone')}</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+62 812 3456 7890"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'contact.form.email')} <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'contact.form.subject')}</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm text-gray-700 transition-colors"
              >
                <option value="">{lang === 'en' ? 'Select a topic' : 'Pilih topik'}</option>
                <option value="Post a Job">{lang === 'en' ? 'Post a Job' : 'Pasang Lowongan'}</option>
                <option value="Therapist Enquiry">{lang === 'en' ? 'Therapist Enquiry' : 'Pertanyaan Terapis'}</option>
                <option value="Get a Quote">{lang === 'en' ? 'Get a Quote' : 'Minta Penawaran'}</option>
                <option value="Other">{lang === 'en' ? 'Other' : 'Lainnya'}</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">{t(lang, 'contact.form.message')} <span class="text-red-500">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder={lang === 'en' ? 'Tell us about your requirements...' : 'Ceritakan kebutuhan Anda...'}
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm resize-none transition-colors"
              ></textarea>
            </div>

            <!-- Honeypot -->
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <input name="fax_number" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <div id="contact-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm"></div>

            <button
              type="submit"
              id="contact-submit"
              class="w-full py-4 rounded-xl bg-[#4a7c3f] text-white font-semibold hover:bg-[#2d5a27] transition-colors disabled:opacity-50"
            >
              {t(lang, 'contact.form.send')}
            </button>

            <p class="text-xs text-gray-400 text-center">
              {t(lang, 'contact.form.successBody')}
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  import { collection, addDoc, serverTimestamp } from 'firebase/firestore';
  import { db } from '../../lib/firebase.js';

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const data = new FormData(form);
    const btn = document.getElementById('contact-submit') as HTMLButtonElement;

    document.getElementById('contact-error')?.classList.add('hidden');

    // Honeypot
    if ((data.get('fax_number') as string)?.trim()) return;

    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const name = data.get('name') as string;
      const email = data.get('email') as string;
      const phone = (data.get('phone') as string) || '';
      const subject = (data.get('subject') as string) || 'General';
      const message = data.get('message') as string;

      // Save to Firestore
      await addDoc(collection(db, 'messages'), {
        name, email, phone, subject, message,
        createdAt: serverTimestamp(),
      });

      // Send email notification
      try {
        await fetch('https://formsubmit.co/ajax/info@spacompany-indonesia.com', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            _subject: `Contact Form: ${subject} — ${name}`,
            'Name': name,
            'Email': email,
            'Phone': phone || '—',
            'Subject': subject,
            'Message': message,
          }),
        });
      } catch (_) { /* best-effort */ }

      form.classList.add('hidden');
      document.getElementById('contact-success')?.classList.remove('hidden');
    } catch (err) {
      const errEl = document.getElementById('contact-error')!;
      errEl.textContent = `Error: ${(err as Error).message}`;
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
