---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — Spa Company Bangkok"
  description="Contact Spa Company Bangkok. We will respond within one business day."
>

  <!-- Page Hero -->
  <section class="bg-[#4a7c3f] py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">Contact Us</h1>
      <p class="text-white/85 text-lg">
        We respond within one business day. Fill in your details below and we'll be in touch.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12">

        <!-- Contact Info + Map -->
        <div class="lg:w-2/5">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Get in Touch</h2>

          <div class="space-y-5 mb-8">
            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">Location</div>
                <div class="text-gray-600 text-sm">Bangkok, Thailand</div>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">Email</div>
                <a href="mailto:info@spa-company.com" class="text-[#4a7c3f] hover:text-[#2d5a27] text-sm transition-colors">
                  info@spa-company.com
                </a>
              </div>
            </div>

            <!-- Facebook -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">Facebook</div>
                <a
                  href="https://www.facebook.com/spacompany/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#4a7c3f] hover:text-[#2d5a27] text-sm transition-colors"
                >
                  facebook.com/spacompany
                </a>
              </div>
            </div>

            <!-- Response time -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-[#4a7c3f]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#4a7c3f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-800 mb-1">Response Time</div>
                <div class="text-gray-600 text-sm">We reply within 1 business day</div>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100">
            <img src="/images/MAP.png" alt="Spa Company Bangkok location map" class="w-full object-cover" />
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:w-3/5">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Send Us a Message</h2>

          <div id="contact-success" class="hidden bg-green-50 border-2 border-green-200 rounded-2xl p-8 text-center">
            <div class="text-3xl mb-2">&#10003;</div>
            <h3 class="text-xl font-bold text-green-800 mb-2">Message Sent!</h3>
            <p class="text-green-700">We'll get back to you within one business day.</p>
          </div>

          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+1 (555) 000-0000"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm transition-colors"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm text-gray-700 transition-colors"
              >
                <option value="">Select a topic</option>
                <option value="Post a Job">Post a Job</option>
                <option value="Therapist Enquiry">Therapist Enquiry</option>
                <option value="Get a Quote">Get a Quote</option>
                <option value="Book Purchase">Book Purchase</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us about your requirements..."
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#4a7c3f]/50 focus:border-[#4a7c3f] text-sm resize-none transition-colors"
              ></textarea>
            </div>

            <!-- Honeypot -->
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <input name="fax_number" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <div id="contact-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm"></div>

            <button
              type="submit"
              id="contact-submit"
              class="w-full py-4 rounded-xl bg-[#4a7c3f] text-white font-semibold hover:bg-[#2d5a27] transition-colors disabled:opacity-50"
            >
              Send Message
            </button>

            <p class="text-xs text-gray-400 text-center">
              We will get back to you within one business day.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  import { collection, addDoc, serverTimestamp } from 'firebase/firestore';
  import { db } from '../lib/firebase.js';

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const data = new FormData(form);
    const btn = document.getElementById('contact-submit') as HTMLButtonElement;

    document.getElementById('contact-error')?.classList.add('hidden');

    // Honeypot
    if ((data.get('fax_number') as string)?.trim()) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const name = data.get('name') as string;
      const email = data.get('email') as string;
      const phone = (data.get('phone') as string) || '';
      const subject = (data.get('subject') as string) || 'General';
      const message = data.get('message') as string;

      // Save to Firestore
      await addDoc(collection(db, 'messages'), {
        name, email, phone, subject, message,
        createdAt: serverTimestamp(),
      });

      // Send email to info@spa-company.com
      try {
        await fetch('https://formsubmit.co/ajax/info@spa-company.com,dadda@spa-company.com,michal@spa-company.com', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            _subject: `Contact Form: ${subject} — ${name}`,
            'Name': name,
            'Email': email,
            'Phone': phone || '—',
            'Subject': subject,
            'Message': message,
          }),
        });
      } catch (_) { /* best-effort */ }

      form.classList.add('hidden');
      document.getElementById('contact-success')?.classList.remove('hidden');
    } catch (err) {
      const errEl = document.getElementById('contact-error')!;
      errEl.textContent = `Error: ${(err as Error).message}`;
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
