---
import Layout from '../layouts/Layout.astro';

const quickGuide = [
  {
    num: 1,
    title: 'Privacy & Data Collection',
    body: 'Provider strictly adheres to international and Thailand standards when it comes to privacy & data collection. We use private information strictly for personal use and never disclose information to third parties.',
  },
  {
    num: 2,
    title: 'Sharing of Personal Data to Approved Candidates',
    body: 'Every successful employee for a client will receive all the personal details of your company, including business registration & passport page, as this is a requirement of Thai authorities to fight human trafficking.',
  },
  {
    num: 3,
    title: 'Service Disclaimer',
    body: 'Provider is an agent that is not responsible for any contract fulfillment between therapist (employee) and employer.',
  },
  {
    num: 4,
    title: 'Guarantee of Service',
    body: 'Provider offers a full guarantee in recruiting. If a therapist cancels the approval process within or after 10 days of approval, the client is entitled to a selection of a new therapist. In case of purchasing "Therapist Light" or "Therapist All-Inclusive", the provider will guarantee the employee or a replacement until the flight overseas.',
  },
  {
    num: 5,
    title: 'Refunds',
    body: 'Full refunds are available strictly and only before any employee approval is done. Client should write the refund request to client@spa-company.com. If no approval of an employee was made, the provider will refund unused funds within 15 days to the client\'s bank account. Bank fees are payable by the client.',
  },
  {
    num: 6,
    title: 'Approval',
    body: 'When the Client approves the Employee on our website, the Employee has 24 hours to approve the job. After the 24-hour mark, the approval is deemed unsuccessful. Approval on both sides (Client and Employee) is deemed as the end selling point and is considered as fulfilling the contract.',
  },
  {
    num: 7,
    title: 'Limitations of Data Accuracy',
    body: 'Provider has several verification and check mechanisms to ensure the data of Employees are as accurate as possible; however, we do not bear any responsibility for personal data correctness. Provider is not liable for misinterpretation of data or for wilful distortion of the data by either Client or Employee.',
  },
];

const articles = [
  {
    title: 'Article 1: Subject and Scope of Business Cooperation',
    content: [
      'The Parties hereto acknowledge that the Client is in business for providing Spa and Massage services to clients and is willing to outsource the hiring, visa, and residency process to Service Provider via the website. The Client will pay for services of the Service Provider.',
      'Service Provider is in business to provide Spa personnel and working visa and residency services, and is willing to provide Spa personnel to the Client.',
      'In accordance with the above, the Service Provider shall: (a) undertake a Selection of future employees of the Client, seeking out and selecting candidates for employment as authentic Thai massage therapists; (b) in the case of the "Therapist All-Inclusive" package, do all required administrative documents and actions related to acquiring work permits, residence permits, and entry visas.',
    ],
  },
  {
    title: 'Article 2: Obligations of the Service Provider',
    content: [
      'As requested by the Client, the Service Provider undertakes to fulfill all demands related to the performance of services as defined in this Agreement and to protect the interests of the Client.',
      'Acceptance Letter is part of the contract as appendix no. 1. The Acceptance Letter states which employees will be offered a working contract. Acceptance signed by both parties is subject to invoicing. The Service Provider will replace the accepted therapist at their own cost, should they cancel before arriving at their destination country.',
    ],
  },
  {
    title: 'Article 3: Obligations of the Client',
    content: [
      'Client undertakes to pay all due monetary obligations incurred as a result of services ordered from the Service Provider in accordance with the Order.',
    ],
  },
  {
    title: 'Article 4: Duration of the Agreement',
    content: [
      'This Agreement shall become effective on the date of execution by both Parties and shall remain in full force indefinitely, until termination in accordance with Article 8. The purpose of the agreement is finished as soon as the Employees are Approved.',
    ],
  },
  {
    title: 'Article 5: Guarantee of Refund',
    content: [
      'The Client can opt out of the contract and demand a full refund when: (a) there has been zero approval of a therapist — Provider will pay a full refund within 15 days; (b) there has been some approval but not the full number of positions filled — the Client will receive a partial unused refund within 15 days; (c) the contract has been fulfilled, but the Client provides a reasonable explanation of cancellation and the employee confirms the Client\'s version, to avoid bypassing the Provider.',
      'In most honest cases, there will be a full refund. Any attempt to bypass the Provider will be deemed as a Breach of Contract and no refund will be provided.',
    ],
  },
  {
    title: 'Article 6: Entry into Force',
    content: [
      'This Agreement shall enter into force when the Provider receives funds into their bank account.',
    ],
  },
];
---

<Layout
  title="Legal Terms — Spa Company Bangkok"
  description="Legal terms and service agreement for Spa Company Bangkok. Quick guide and full service agreement between Client and Service Provider."
>

  <!-- Hero -->
  <section class="bg-gray-900 py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-white mb-4">Legal Terms</h1>
      <p class="text-gray-400 text-lg">
        As nobody likes to read 137 pages of Terms &amp; Conditions, we've highlighted the most important ones.
      </p>
    </div>
  </section>

  <!-- Quick Guide -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Legal Terms Quick Guide</h2>
      <p class="text-gray-500 mb-8 text-sm uppercase tracking-wide font-medium">
        Explanation of terms: Spa Company Bangkok = <strong>Provider</strong> &nbsp;|&nbsp; Thai Therapist Approved for Job = <strong>Employee</strong>
      </p>

      <div class="space-y-6">
        {quickGuide.map((item) => (
          <div class="flex items-start gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50">
            <div class="w-8 h-8 rounded-full bg-[#4a7c3f] flex items-center justify-center shrink-0 text-white font-bold text-sm">
              {item.num}
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full Service Agreement -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Service Agreement</h2>
      <p class="text-gray-500 mb-8 text-sm">
        Between <strong>CLIENT Co., Ltd.</strong> (the "Client") and <strong>SPA COMPANY BANGKOK Co Ltd</strong>, Bangkok, Thailand (the "Service Provider"), hereinafter jointly referred to as the "Parties".
      </p>

      <div class="space-y-8">
        {articles.map((article) => (
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <h3 class="font-bold text-[#4a7c3f] uppercase tracking-wide text-sm mb-4">{article.title}</h3>
            <div class="space-y-3">
              {article.content.map((para) => (
                <p class="text-gray-600 text-sm leading-relaxed">{para}</p>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 p-5 bg-[#4a7c3f]/10 rounded-2xl border border-[#4a7c3f]/20">
        <p class="text-sm text-gray-700">
          For refund requests or legal inquiries, contact us at{' '}
          <a href="mailto:client@spa-company.com" class="text-[#4a7c3f] hover:text-[#2d5a27] font-medium underline">
            client@spa-company.com
          </a>
        </p>
      </div>
    </div>
  </section>

</Layout>
