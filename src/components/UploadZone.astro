---
// UploadZone.astro — Three drag-and-drop upload slots for candidate intake
// Passport PDF, CV PDF, and Photos (JPG/PNG, multiple)
---

<div id="upload-zone" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
  <h2 class="font-semibold text-gray-900 text-lg mb-1">Upload Documents</h2>
  <p class="text-sm text-gray-500 mb-6">Upload all three to enable AI extraction.</p>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">

    <!-- Passport PDF slot -->
    <div
      id="slot-passport"
      class="upload-slot flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-6 cursor-pointer hover:border-[#4a7c3f] hover:bg-green-50 transition-colors min-h-[140px] relative"
      data-slot="passport"
      data-accept=".pdf,application/pdf"
    >
      <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="text-sm font-medium text-gray-600">Passport</p>
      <p class="text-xs text-gray-400 mt-0.5">PDF only</p>
      <div id="passport-status" class="absolute bottom-2 left-0 right-0 px-2 text-center text-xs text-[#2d5a27] font-medium hidden"></div>
      <input id="input-passport" type="file" accept=".pdf,application/pdf" class="hidden" />
    </div>

    <!-- CV PDF slot -->
    <div
      id="slot-cv"
      class="upload-slot flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-6 cursor-pointer hover:border-[#4a7c3f] hover:bg-green-50 transition-colors min-h-[140px] relative"
      data-slot="cv"
      data-accept=".pdf,application/pdf"
    >
      <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <p class="text-sm font-medium text-gray-600">CV / Resume</p>
      <p class="text-xs text-gray-400 mt-0.5">PDF only</p>
      <div id="cv-status" class="absolute bottom-2 left-0 right-0 px-2 text-center text-xs text-[#2d5a27] font-medium hidden"></div>
      <input id="input-cv" type="file" accept=".pdf,application/pdf" class="hidden" />
    </div>

    <!-- Photos slot -->
    <div
      id="slot-photos"
      class="upload-slot flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-6 cursor-pointer hover:border-[#4a7c3f] hover:bg-green-50 transition-colors min-h-[140px] relative"
      data-slot="photos"
      data-accept="image/jpeg,image/png,image/jpg"
    >
      <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="text-sm font-medium text-gray-600">Photos</p>
      <p class="text-xs text-gray-400 mt-0.5">JPG / PNG, multiple</p>
      <div id="photos-status" class="absolute bottom-2 left-0 right-0 px-2 text-center text-xs text-[#2d5a27] font-medium hidden"></div>
      <input id="input-photos" type="file" accept="image/jpeg,image/png,image/jpg" multiple class="hidden" />
    </div>
    <!-- Country ID Card slot (optional) -->
    <div
      id="slot-idcard"
      class="upload-slot flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-6 cursor-pointer hover:border-[#4a7c3f] hover:bg-green-50 transition-colors min-h-[140px] relative"
      data-slot="idcard"
      data-accept=".pdf,application/pdf,image/jpeg,image/png,image/jpg"
    >
      <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
      </svg>
      <p class="text-sm font-medium text-gray-600">Country ID Card</p>
      <p class="text-xs text-gray-400 mt-0.5">PDF or image — optional</p>
      <div id="idcard-status" class="absolute bottom-2 left-0 right-0 px-2 text-center text-xs text-[#2d5a27] font-medium hidden"></div>
      <input id="input-idcard" type="file" accept=".pdf,application/pdf,image/jpeg,image/png,image/jpg" class="hidden" />
    </div>
  </div>

  <!-- Photo previews -->
  <div id="photo-previews" class="flex flex-wrap gap-2 mb-4 hidden">
    <p class="w-full text-xs font-medium text-gray-500 mb-1">Photo previews:</p>
  </div>

  <!-- Error message -->
  <p id="upload-error" class="text-red-500 text-sm mb-3 hidden"></p>

  <!-- Process button -->
  <button
    id="process-btn"
    disabled
    class="w-full py-3 bg-[#4a7c3f] text-white font-semibold rounded-xl hover:bg-[#2d5a27] transition-colors disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.347.347a3.82 3.82 0 01-1.197 2.309A3.822 3.822 0 0112 20.25a3.822 3.822 0 01-2.794-1.194 3.82 3.82 0 01-1.197-2.309L7.66 16.34z" />
    </svg>
    Populate Form
  </button>
  <p id="process-status" class="text-sm text-gray-500 text-center mt-2 hidden"></p>
</div>

<script>
  import { ref, uploadBytes, getDownloadURL } from 'firebase/storage';
  import { storage, callFunction } from '../lib/firebase.js';

  interface UploadedFiles {
    passport: File | null;
    cv: File | null;
    photos: File[];
    idcard: File | null;
  }

  const uploaded: UploadedFiles = { passport: null, cv: null, photos: [], idcard: null };
  window.__storageUrls = { passport: '', cv: '', photos: [], idcard: '' };

  const processBtn = document.getElementById('process-btn') as HTMLButtonElement;
  const uploadError = document.getElementById('upload-error')!;
  const processStatus = document.getElementById('process-status')!;
  const previewsContainer = document.getElementById('photo-previews')!;

  function setSlotStatus(slot: string, filename: string) {
    const slotEl = document.getElementById(`slot-${slot}`)!;
    const statusEl = document.getElementById(`${slot}-status`)!;
    slotEl.classList.add('border-[#4a7c3f]', 'bg-green-50');
    slotEl.classList.remove('border-gray-300');
    statusEl.textContent = filename;
    statusEl.classList.remove('hidden');
  }

  function checkReady() {
    const ready = uploaded.passport !== null && uploaded.cv !== null && uploaded.photos.length > 0;
    processBtn.disabled = !ready;
  }

  function handlePassportOrCv(slot: 'passport' | 'cv', file: File) {
    if (file.type !== 'application/pdf') {
      uploadError.textContent = 'Only PDF files are accepted for passport and CV.';
      uploadError.classList.remove('hidden');
      return;
    }
    uploadError.classList.add('hidden');
    uploaded[slot] = file;
    const name = file.name.length > 24 ? file.name.slice(0, 21) + '…' : file.name;
    setSlotStatus(slot, name);
    checkReady();
  }

  function handlePhotos(files: FileList) {
    const validFiles = Array.from(files).filter(f => f.type.startsWith('image/'));
    if (validFiles.length === 0) {
      uploadError.textContent = 'Please select JPG or PNG images.';
      uploadError.classList.remove('hidden');
      return;
    }
    uploadError.classList.add('hidden');
    uploaded.photos = validFiles;
    setSlotStatus('photos', `${validFiles.length} photo${validFiles.length > 1 ? 's' : ''}`);

    // Show previews
    previewsContainer.classList.remove('hidden');
    // Remove old preview images but keep the label
    previewsContainer.querySelectorAll('img').forEach(img => img.remove());
    validFiles.forEach(file => {
      const url = URL.createObjectURL(file);
      const img = document.createElement('img');
      img.src = url;
      img.className = 'w-16 h-16 object-cover rounded-lg border border-gray-200';
      previewsContainer.appendChild(img);
    });

    checkReady();
  }

  function handleIdCard(file: File) {
    const validTypes = ['application/pdf', 'image/jpeg', 'image/png', 'image/jpg'];
    if (!validTypes.includes(file.type)) {
      uploadError.textContent = 'ID card must be PDF, JPG, or PNG.';
      uploadError.classList.remove('hidden');
      return;
    }
    uploadError.classList.add('hidden');
    uploaded.idcard = file;
    const name = file.name.length > 24 ? file.name.slice(0, 21) + '…' : file.name;
    setSlotStatus('idcard', name);
  }

  // Wire up click and drag-drop for each slot
  function setupSlot(slotId: string, inputId: string) {
    const slotEl = document.getElementById(slotId)!;
    const inputEl = document.getElementById(inputId) as HTMLInputElement;

    slotEl.addEventListener('click', () => inputEl.click());

    inputEl.addEventListener('change', () => {
      if (!inputEl.files || inputEl.files.length === 0) return;
      if (slotId === 'slot-passport') handlePassportOrCv('passport', inputEl.files[0]);
      else if (slotId === 'slot-cv') handlePassportOrCv('cv', inputEl.files[0]);
      else if (slotId === 'slot-photos') handlePhotos(inputEl.files);
      else if (slotId === 'slot-idcard') handleIdCard(inputEl.files[0]);
    });

    slotEl.addEventListener('dragover', (e) => {
      e.preventDefault();
      slotEl.classList.add('border-[#4a7c3f]', 'bg-green-50');
    });

    slotEl.addEventListener('dragleave', () => {
      if (!uploaded.passport && slotId === 'slot-passport') slotEl.classList.remove('border-[#4a7c3f]', 'bg-green-50');
      if (!uploaded.cv && slotId === 'slot-cv') slotEl.classList.remove('border-[#4a7c3f]', 'bg-green-50');
      if (uploaded.photos.length === 0 && slotId === 'slot-photos') slotEl.classList.remove('border-[#4a7c3f]', 'bg-green-50');
      if (!uploaded.idcard && slotId === 'slot-idcard') slotEl.classList.remove('border-[#4a7c3f]', 'bg-green-50');
    });

    slotEl.addEventListener('drop', (e) => {
      e.preventDefault();
      const dt = (e as DragEvent).dataTransfer;
      if (!dt || !dt.files || dt.files.length === 0) return;
      if (slotId === 'slot-passport') handlePassportOrCv('passport', dt.files[0]);
      else if (slotId === 'slot-cv') handlePassportOrCv('cv', dt.files[0]);
      else if (slotId === 'slot-photos') handlePhotos(dt.files);
      else if (slotId === 'slot-idcard') handleIdCard(dt.files[0]);
    });
  }

  setupSlot('slot-passport', 'input-passport');
  setupSlot('slot-cv', 'input-cv');
  setupSlot('slot-photos', 'input-photos');
  setupSlot('slot-idcard', 'input-idcard');

  // Process documents
  processBtn.addEventListener('click', async () => {
    if (!uploaded.passport || !uploaded.cv || uploaded.photos.length === 0) return;

    processBtn.disabled = true;
    processBtn.innerHTML = `
      <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      Uploading…
    `;
    processStatus.textContent = 'Uploading documents to secure storage…';
    processStatus.classList.remove('hidden');
    uploadError.classList.add('hidden');

    try {
      const tempId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;

      // Upload passport
      const passportRef = ref(storage, `candidates/${tempId}/passport.pdf`);
      const passportSnap = await uploadBytes(passportRef, uploaded.passport!);
      const passportUrl = await getDownloadURL(passportSnap.ref);

      // Upload CV
      const cvRef = ref(storage, `candidates/${tempId}/cv.pdf`);
      const cvSnap = await uploadBytes(cvRef, uploaded.cv!);
      const cvUrl = await getDownloadURL(cvSnap.ref);

      // Upload photos
      const photoUrls: string[] = [];
      for (let i = 0; i < uploaded.photos.length; i++) {
        const photo = uploaded.photos[i];
        const ext = photo.name.split('.').pop() || 'jpg';
        const photoRef = ref(storage, `candidates/${tempId}/photo-${i}.${ext}`);
        const photoSnap = await uploadBytes(photoRef, photo);
        photoUrls.push(await getDownloadURL(photoSnap.ref));
      }

      // Upload ID card (optional)
      let idcardUrl = '';
      if (uploaded.idcard) {
        const ext = uploaded.idcard.name.split('.').pop() || 'pdf';
        const idcardRef = ref(storage, `candidates/${tempId}/idcard.${ext}`);
        const idcardSnap = await uploadBytes(idcardRef, uploaded.idcard);
        idcardUrl = await getDownloadURL(idcardSnap.ref);
      }

      window.__storageUrls = { passport: passportUrl, cv: cvUrl, photos: photoUrls, idcard: idcardUrl };

      processBtn.innerHTML = `
        <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Extracting data with AI…
      `;
      processStatus.textContent = 'Running AI extraction on documents…';

      const result = await callFunction('processDocuments', {
        tempId,
        passportUrl,
        cvUrl,
        idcardUrl: idcardUrl || null,
        photoUrls,
      }) as { data: Record<string, unknown> };

      document.dispatchEvent(new CustomEvent('ocr-complete', { detail: result.data }));

      processBtn.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Form Populated
      `;
      processStatus.textContent = 'Form populated from documents. Review and edit below.';
      processBtn.classList.add('bg-green-600');
      processBtn.classList.remove('bg-[#4a7c3f]', 'hover:bg-[#2d5a27]');

    } catch (err) {
      uploadError.textContent = `Processing failed: ${(err as Error).message}`;
      uploadError.classList.remove('hidden');
      processBtn.disabled = false;
      processBtn.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.347.347a3.82 3.82 0 01-1.197 2.309A3.822 3.822 0 0112 20.25a3.822 3.822 0 01-2.794-1.194 3.82 3.82 0 01-1.197-2.309L7.66 16.34z" />
        </svg>
        Populate Form
      `;
      processStatus.classList.add('hidden');
    }
  });
</script>
