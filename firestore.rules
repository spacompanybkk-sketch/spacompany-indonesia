rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /therapists/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /orders/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /jobs/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /messages/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /enquiries/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
